# ── Required ──────────────────────────────────────────────────────────────────
# Gemini LLM (primary AI) + Gemini Embeddings for Redis RAG
GOOGLE_API_KEY=

# Groq Whisper STT + Groq Llama LLM (tier 2 fallback)
GROQ_API_KEY=

# HuggingFace SDXL — AI texture generation
HF_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────────
# ElevenLabs TTS voice (auto-disabled if quota exceeded or key missing)
ELEVENLABS_API_KEY=

# GitHub Models LLM fallback (tier 3)
GITHUB_API_KEY=

# ── Local GPU Mode ────────────────────────────────────────────────────────────
# Set to LOCAL_GPU to use local Whisper + XTTS-v2 + SDXL on GPU (EC2 g5 / local GPU)
# Leave empty for cloud API mode (default)
AI_MODEL_MODE=

# ── Rate Limit Protection ─────────────────────────────────────────────────────
# Set to true to throttle embedding calls (protects against Gemini free-tier 429s)
DEMO_MODE=false

# ── AWS Cloud RAG (Production) ────────────────────────────────────────────────
# Set to true to use OpenSearch instead of local Redis for knowledge RAG
USE_AWS_RAG=false

# Required if USE_AWS_RAG=true
OPENSEARCH_ENDPOINT=

# AWS region (default: us-east-1)
AWS_REGION=us-east-1
