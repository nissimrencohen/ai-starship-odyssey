# ── Deploy Configuration ─────────────────────────────────────────────────────
# Copy this file to deploy/.env.deploy and fill in your values.
# deploy/.env.deploy is in .gitignore and will NEVER be committed.
#
# How to get these values:
#   AWS_ACCOUNT_ID   → aws sts get-caller-identity --query Account --output text
#   EC2 IDs/IPs      → aws ec2 describe-instances (after launching)
#   CloudFront ID    → aws cloudfront list-distributions
#   S3 buckets       → aws s3 ls
#   Redis URL        → aws elasticache describe-cache-clusters
#   OpenSearch URL   → aws opensearch describe-domain --domain-name starship-knowledge
#
# See AWS_ARCHITECTURE.md for full one-time setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# AWS Account
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID
AWS_REGION=us-east-1

# EC2 Instance IDs + Public IPs (update whenever instances are replaced)
DIRECTOR_INSTANCE=i-XXXXXXXXXXXXXXXXX
DIRECTOR_IP=0.0.0.0
RUST_INSTANCE=i-XXXXXXXXXXXXXXXXX
RUST_IP=0.0.0.0

# CloudFront (single HTTPS domain for all traffic)
CLOUDFRONT_DOMAIN=XXXXXXXXXXXX.cloudfront.net
CLOUDFRONT_ID=XXXXXXXXXXXXX

# S3 Buckets (include account ID suffix to ensure global uniqueness)
S3_FRONTEND_BUCKET=starship-frontend-YOUR_ACCOUNT_ID
S3_SAVES_BUCKET=starship-game-saves-YOUR_ACCOUNT_ID
S3_LORE_BUCKET=starship-lore-docs-YOUR_ACCOUNT_ID

# Managed AWS Endpoints
REDIS_URL=redis://YOUR_CLUSTER.XXXXX.0001.use1.cache.amazonaws.com:6379
OPENSEARCH_URL=https://vpc-YOUR_DOMAIN.us-east-1.es.amazonaws.com

# NOTE: API keys (GOOGLE_API_KEY, GROQ_API_KEY, etc.) are loaded from root .env
# Do not put API keys in this file — they are already excluded via root .env
